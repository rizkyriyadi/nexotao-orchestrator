# Root env for docker-compose. Copy to `.env` and fill in.
APP_PASSWORD=change-me-to-a-strong-password
JWT_SECRET=change-me-to-a-long-random-string
# Required for Docker deploys (no CLI login inside the container):
ANTHROPIC_API_KEY=sk-ant-...
# Optional Neon/Postgres URL. If empty, history is in-memory (lost on restart).
DATABASE_URL=
# bypassPermissions | acceptEdits | default | plan
PERMISSION_MODE=acceptEdits
