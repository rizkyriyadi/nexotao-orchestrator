# ---- Auth ----
# Password to log into the web UI. CHANGE THIS.
APP_PASSWORD=changeme
# Secret used to sign the session cookie/JWT. Use a long random string.
JWT_SECRET=please-change-me-to-a-long-random-string
# Session lifetime and login abuse controls (safe defaults shown).
SESSION_TTL_SECONDS=43200
LOGIN_MAX_FAILURES=5
LOGIN_WINDOW_MS=600000
LOGIN_BLOCK_MS=900000

# ---- Anthropic ----
# Optional. If you're logged in via the `claude` CLI (subscription), you can
# leave this empty and the Agent SDK will use that auth. Otherwise set a key.
ANTHROPIC_API_KEY=

# ---- Agent ----
# The agent's "project home" — where it defaults to creating new projects
# (e.g. `create-next-app` lands in AGENT_CWD/<name>). The agent still has FULL
# host access via absolute paths; this is just its default working directory.
# Defaults to ./workspace next to the server. For a real VM, point it at a
# dedicated projects folder you can find easily, e.g. /home/you/claude-projects
AGENT_CWD=
# Permission mode: plan (default) | acceptEdits | default | bypassPermissions
PERMISSION_MODE=plan
# Required only for bypassPermissions. The warning remains visible in every
# authenticated dangerous-mode session.
DANGEROUS_MODE_ACKNOWLEDGEMENT=
# Per-task reservation used before any worker provider call. Actual provider
# cost replaces the reservation at completion; see docs/security-boundary.md.
ORCE_TASK_RESERVATION_USD=0.50

# ---- Knowledge graph (optional) ----
# Give agents a graphify knowledge-graph tool for the workspace so they
# understand project structure instead of grepping blindly. No-op unless
# graphify is installed WITH the mcp extra:
#   uv tool install graphifyy --with mcp
# Set to false to disable.
GRAPH_ENABLED=true

# ---- Database ----
# Plug & play: with no DATABASE_URL, the server uses an EMBEDDED local Postgres
# (PGlite) that persists to ~/.nexotao-orce/db — zero setup, survives restarts.
# Set DATABASE_URL to use a hosted Neon/Postgres instead.
DATABASE_URL=
# Set NEXOTAO_DB=memory to force ephemeral in-memory storage (no persistence).
NEXOTAO_DB=

# ---- Server ----
PORT=8787
# Loopback is the tested default. Binding beyond loopback changes diagnostics
# to network_exposed and requires an HTTPS reverse proxy.
HOST=127.0.0.1
TRUST_PROXY=false
